{
    "name": "laravel-cli-tool/lx",
    "description": "A Laravel developer CLI companion for scaffolding, linting, and project health checks.",
    "keywords": ["laravel", "cli", "console", "developer-tools", "scaffolding"],
    "homepage": "https://github.com/laravel-cli-tool/lx",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/laravel-cli-tool/lx/issues",
        "source": "https://github.com/laravel-cli-tool/lx"
    },
    "authors": [
        {
            "name": "Laravel CLI Tool",
            "email": "maintainers@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel-zero/framework": "^12.0.2"
    },
    "require-dev": {
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "php vendor/bin/pest --colors=always",
        "lint": "php vendor/bin/pint --test",
        "lint:fix": "php vendor/bin/pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["lx"]
}
